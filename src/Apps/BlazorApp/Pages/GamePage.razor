@page "/games/{Slug}"
@layout GameLayout
@inject IEnumerable<IGalleryGame> GalleryGames

@if (_stage is not null)
{
    <PageTitle>@_entry!.Title – SkiaSharp Games</PageTitle>
    <GameView Stage="_stage" />
}
else
{
    <PageTitle>Game Not Found – SkiaSharp Games</PageTitle>
    <p>Game "@Slug" not found.</p>
}

@code {
    [Parameter] public string Slug { get; set; } = "";

    private IGalleryGame? _entry;
    private Stage? _stage;

    protected override void OnParametersSet()
    {
        _entry = GalleryGames.FirstOrDefault(g =>
            string.Equals(g.Slug, Slug, StringComparison.OrdinalIgnoreCase));
        _stage = _entry?.CreateStage();
    }
}
